# Database
DB_USERNAME=tourmaster_user
DB_PASSWORD=changeme_strong_password

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_256bit_random_hex
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Mail (Gmail example — use App Password, not account password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@tourmaster.ua
MAIL_PASSWORD=gmail_app_password

# Public URL of your deployment (set to https://yourdomain.com in production)
FRONTEND_URL=http://localhost
APP_DOMAIN=yourdomain.com
